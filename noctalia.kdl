layout {

    focus-ring {
        active-color   "#c1c5e1"
        inactive-color "#131315"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#c1c5e1"
        inactive-color "#131315"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#c1c5e1"
        inactive-color "#a4a8c3"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#c1c5e180"
    }
}

recent-windows {
    highlight {
        active-color "#c1c5e1"
        urgent-color "#ffb4ab"
    }
}
